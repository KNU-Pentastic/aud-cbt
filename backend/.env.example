# ---- App ----
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+psycopg2://aud:aud@localhost:5432/aud_cbt
DATABASE_URL_ASYNC=postgresql+asyncpg://aud:aud@localhost:5432/aud_cbt

# ---- Redis (optional cache/session) ----
REDIS_URL=redis://localhost:6379/0

# ---- JWT ----
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
PATIENT_TOKEN_TTL_SECONDS=86400
PROVIDER_TOKEN_TTL_SECONDS=28800

# ---- PII encryption (Fernet) ----
# 저장 PII(이름·전화·발화 원문) 암호화 키. Fernet base64 32B 형식.
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 비우면 개발 편의상 JWT_SECRET 에서 파생한다(운영 금지 — APP_ENV=production 이면 필수).
PII_ENCRYPTION_KEY=

# ---- Internal Service Auth ----
# Comma-separated whitelist of X-Internal-Service-Key values. Each component
# should hold its own key in production; for local dev a single key is fine.
INTERNAL_SERVICE_KEYS=dev-internal-key-change-me

# ---- LLM ----
# If unset OR USE_LLM_MOCK=true, the gateway returns deterministic mock output.
ANTHROPIC_API_KEY=
USE_LLM_MOCK=true
LLM_DAILY_TOKEN_QUOTA=200000
LLM_MODEL_DIALOGUE=claude-opus-4-7
LLM_MODEL_TRACKING=claude-sonnet-4-6
LLM_MODEL_CLASSIFIER=claude-haiku-4-5
# 라이브 대화 응답에 "참고한 프롬프트"와 "주차/단계 진행도"를 SSE 로 노출(데모/디버깅용).
# 운영 배포 시 false 권장.
LLM_TRACE=true

# ---- Patient registration code ----
REGISTRATION_CODE_TTL_DAYS=7

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
